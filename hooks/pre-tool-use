#!/usr/bin/env bash
# =============================================================================
# pre-tool-use — Production Framework v2.4.0 hook
#
# Reads .framework-state/active-gates.yaml and enforces the active set of
# HARD-GATEs per the configure-project-gates skill's output.
#
# Three layers of enforcement:
#   1. Universal floor (hardcoded, always-active) — pre_tool_use class only:
#        heavy-read-dispatch, no-pii-in-logs, data-loss-disclosure
#   2. Legacy fixed gates (preserved from v2.0+):
#        tier-selection, destructive-ops, dep-add
#   3. Config-driven configurable gates from .framework-state/active-gates.yaml:
#        Agent/Task gates: worktree-preflight, builder-execute-verb-scope
#        Write gates: find-similar-implementations
#
# Every deny + every bypass writes one JSON line to .framework-state/decision-log.jsonl
#
# Three-tier bypass grammar (preserved):
#   PF_BYPASS=<rule-id>                     per-rule
#   PF_BYPASS_ALL=1 + PF_BYPASS_REASON      session-wide
#   .framework-state/PF_GATES_DISABLED      kill switch
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PROJECT_DIR="${CLAUDE_PROJECT_DIR:-$(pwd)}"
STATE_DIR="${PROJECT_DIR}/.framework-state"
SESSION_FILE="${STATE_DIR}/session.json"
BYPASS_LOG="${STATE_DIR}/bypass-log.jsonl"
DECISION_LOG="${STATE_DIR}/decision-log.jsonl"
ACTIVE_GATES="${STATE_DIR}/active-gates.yaml"
WARN_COUNTS="${STATE_DIR}/warn-counts.json"
KILL_SWITCH="${STATE_DIR}/PF_GATES_DISABLED"

INPUT=$(cat)

# =============================================================================
# Helpers (defined before any tool-dispatch logic)
# =============================================================================

ensure_state_dir() {
  mkdir -p "${STATE_DIR}"
  if [ ! -f "${SESSION_FILE}" ]; then
    cat > "${SESSION_FILE}" <<EOF
{
  "session_started_at": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "tier_selection_invoked_at": "",
  "triage_invoked_at": "",
  "last_user_prompt_at": "",
  "read_count_current_deliverable": 0
}
EOF
  fi
  [ -f "${WARN_COUNTS}" ] || echo '{}' > "${WARN_COUNTS}"
}

update_skill_timestamp() {
  # HIGH-1 fix (QA findings 2026-05-17): if the field is missing from session.json
  # (schema-incomplete file), sed does nothing silently. Detect-and-insert instead.
  ensure_state_dir
  local skill_field="$1"
  local now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  local tmp=$(mktemp)
  if grep -q "\"${skill_field}\"" "${SESSION_FILE}" 2>/dev/null; then
    # Field present: substitute
    sed -E "s/\"${skill_field}\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/\"${skill_field}\": \"${now}\"/" "${SESSION_FILE}" > "${tmp}"
  else
    # Field missing: insert before closing brace (same pattern as warn_increment + increment_read_count)
    sed -E "s/\\}\$/,\"${skill_field}\": \"${now}\"}/" "${SESSION_FILE}" > "${tmp}"
  fi
  mv "${tmp}" "${SESSION_FILE}"
}

increment_read_count() {
  ensure_state_dir
  local cur
  cur=$(grep -o '"read_count_current_deliverable"[[:space:]]*:[[:space:]]*[0-9]*' "${SESSION_FILE}" 2>/dev/null | sed 's/.*: *//' || echo "0")
  local new=$((cur + 1))
  local tmp=$(mktemp)
  if grep -q '"read_count_current_deliverable"' "${SESSION_FILE}" 2>/dev/null; then
    sed -E "s/\"read_count_current_deliverable\"[[:space:]]*:[[:space:]]*[0-9]+/\"read_count_current_deliverable\": ${new}/" "${SESSION_FILE}" > "${tmp}"
  else
    # Insert the field if missing
    sed -E "s/\\}$/,\"read_count_current_deliverable\": ${new}}/" "${SESSION_FILE}" > "${tmp}"
  fi
  mv "${tmp}" "${SESSION_FILE}"
  echo "${new}"
}

reset_read_count() {
  ensure_state_dir
  local tmp=$(mktemp)
  if grep -q '"read_count_current_deliverable"' "${SESSION_FILE}" 2>/dev/null; then
    sed -E "s/\"read_count_current_deliverable\"[[:space:]]*:[[:space:]]*[0-9]+/\"read_count_current_deliverable\": 0/" "${SESSION_FILE}" > "${tmp}"
    mv "${tmp}" "${SESSION_FILE}"
  fi
}

json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  printf '%s' "$s"
}

log_decision() {
  ensure_state_dir
  local decision="$1"
  local gate_id="$2"
  local reason
  reason="$(json_escape "${3:-}")"
  local ts
  ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  printf '{"timestamp":"%s","decision":"%s","gate":"%s","reason":"%s","tool":"%s"}\n' \
    "$ts" "$decision" "$gate_id" "$reason" "${TOOL_NAME:-}" >> "${DECISION_LOG}"
}

log_bypass() {
  ensure_state_dir
  local rule_id="$1"
  local reason="${2:-}"
  local ts
  ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  printf '{"timestamp":"%s","rule":"%s","reason":"%s"}\n' "$ts" "$rule_id" "$(json_escape "${reason}")" >> "${BYPASS_LOG}"
  log_decision "bypass" "${rule_id}" "${reason}"
}

log_invocation() {
  ensure_state_dir
  local event_type="$1"
  local name="$2"
  local ts
  ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  printf '{"timestamp":"%s","event":"%s","name":"%s"}\n' "$ts" "$event_type" "$name" >> "${STATE_DIR}/trigger-audit.jsonl"
}

allow() {
  printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"allow"}}\n'
  exit 0
}

deny() {
  local reason
  reason="$(json_escape "$1")"
  local gate_id="${2:-unknown}"
  log_decision "deny" "${gate_id}" "$1"
  printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDecisionReason":"%s"}}\n' "$reason"
  exit 0
}

# Increment warn count for a gate; print new count
warn_increment() {
  ensure_state_dir
  local gate_id="$1"
  local current
  current=$(grep -o "\"${gate_id}\"[[:space:]]*:[[:space:]]*[0-9]*" "${WARN_COUNTS}" 2>/dev/null | sed 's/.*: *//' || echo "0")
  local new=$((current + 1))
  if grep -q "\"${gate_id}\"" "${WARN_COUNTS}" 2>/dev/null; then
    local tmp=$(mktemp)
    sed -E "s/\"${gate_id}\"[[:space:]]*:[[:space:]]*[0-9]+/\"${gate_id}\": ${new}/" "${WARN_COUNTS}" > "${tmp}"
    mv "${tmp}" "${WARN_COUNTS}"
  else
    # Insert. Handle "{}" empty case + "{...}" non-empty case
    if [ "$(cat "${WARN_COUNTS}")" = "{}" ]; then
      echo "{\"${gate_id}\": ${new}}" > "${WARN_COUNTS}"
    else
      local tmp=$(mktemp)
      sed -E "s/\\}$/,\"${gate_id}\": ${new}}/" "${WARN_COUNTS}" > "${tmp}"
      mv "${tmp}" "${WARN_COUNTS}"
    fi
  fi
  echo "${new}"
}

# warn_handle gate_id enforcement_mode max_per_session message
# - block → deny (or bypass)
# - warn → increment count; if exceeds max, escalate to block
# - audit → log only
warn_handle() {
  local gate_id="$1"
  local mode="$2"
  local max="$3"
  local message="$4"

  if [ "${PF_BYPASS:-}" = "${gate_id}" ]; then
    log_bypass "${gate_id}" "explicit bypass"
    return 0
  fi

  case "${mode}" in
    block)
      deny "${message}" "${gate_id}"
      ;;
    warn)
      local count
      count=$(warn_increment "${gate_id}")
      if [ -n "${max}" ] && [ "${max}" != "null" ] && [ "${count}" -gt "${max}" ]; then
        deny "${message} [Escalated to block: ${count} warns this session exceeds max_per_session=${max}.]" "${gate_id}"
      fi
      log_decision "warn" "${gate_id}" "${message} (count: ${count}/${max:-∞})"
      ;;
    audit)
      log_decision "audit" "${gate_id}" "${message}"
      ;;
  esac
  return 0
}

# check_active_gates_for_agent_dispatch
# Called when TOOL_NAME == Agent or Task.
# Enforces worktree-preflight + builder-execute-verb-scope IFF listed in active-gates.yaml.
check_active_gates_for_agent_dispatch() {
  [ ! -f "${ACTIVE_GATES}" ] && return 0
  [ "${SUBAGENT_TYPE}" != "production-framework:builder" ] && return 0

  # worktree-preflight
  if grep -q "id: worktree-preflight" "${ACTIVE_GATES}" 2>/dev/null; then
    if [ "${PF_BYPASS:-}" != "worktree-preflight" ]; then
      local git_dirty=""
      git_dirty=$(cd "${PROJECT_DIR}" && git status --porcelain 2>/dev/null | head -1 || echo "")
      local has_pinned_sha=0
      if printf '%s' "${AGENT_PROMPT}" | grep -qE '(BASE_SHA|pinned SHA|HEAD=[a-f0-9]{7,}|git rev-parse HEAD)'; then
        has_pinned_sha=1
      fi
      if [ -n "${git_dirty}" ] || [ "${has_pinned_sha}" -eq 0 ]; then
        deny "worktree-preflight (FEEDBACK WORKTREE consolidates F-V10/11/21/25/27): Builder worktree dispatch needs (a) clean git status AND (b) BASE_SHA / pinned-SHA in dispatch prompt. Currently git status: ${git_dirty:+dirty}${git_dirty:-clean}; pinned SHA detected: ${has_pinned_sha}. Commit design artifacts first; pass BASE_SHA via 'git rev-parse HEAD'. Bypass: PF_BYPASS=worktree-preflight." "worktree-preflight"
      fi
      # F-6 (2026-05-17) — 4th sub-pattern: HEAD-parity check. Builder auto-worktree
      # spawns from session-START parent-branch state, NOT current HEAD. If user did
      # `git checkout` to another branch and committed mid-session, the spawn base
      # is stale. Compare session-start SHA (captured by session-start hook) against
      # current main-session HEAD; deny if they diverge.
      local session_start_sha=""
      if [ -f "${STATE_DIR}/session-start.json" ]; then
        session_start_sha=$(grep -o '"sha"[[:space:]]*:[[:space:]]*"[^"]*"' "${STATE_DIR}/session-start.json" 2>/dev/null | sed 's/.*: *"\(.*\)"/\1/' || echo "")
      fi
      local current_head_sha=""
      current_head_sha=$(cd "${PROJECT_DIR}" && git rev-parse HEAD 2>/dev/null || echo "")
      if [ -n "${session_start_sha}" ] && [ -n "${current_head_sha}" ] && [ "${session_start_sha}" != "${current_head_sha}" ]; then
        deny "worktree-preflight (F-6, 2026-05-17, 4th sub-pattern): main-session HEAD has diverged from session-start state. session-start SHA: ${session_start_sha:0:7}; current HEAD: ${current_head_sha:0:7}. Builder auto-worktree spawns from session-START parent-branch state, NOT current HEAD — a stale-base dispatch would silently use the wrong tree. Options: (a) re-dispatch via 'general-purpose' agent type (no isolation hardcoding) + document the Builder-discipline trade-off in commit body, or (b) restart the Claude Code session so session-start SHA matches current HEAD, or (c) PF_BYPASS=worktree-preflight if intentional." "worktree-preflight"
      fi
    else
      log_bypass "worktree-preflight" "explicit bypass"
    fi
  fi

  # builder-execute-verb-scope
  if grep -q "id: builder-execute-verb-scope" "${ACTIVE_GATES}" 2>/dev/null; then
    if [ "${PF_BYPASS:-}" != "builder-execute-verb-scope" ]; then
      if ! printf '%s' "${AGENT_PROMPT}" | grep -qE '^EXECUTE|\\nEXECUTE'; then
        deny "builder-execute-verb-scope (F-V7, ~83% Sonnet recurrence): Builder dispatch must open with the EXECUTE verb (uppercase). Ambiguous 'execute the plan' produces empty-diff silent failures. Bypass: PF_BYPASS=builder-execute-verb-scope." "builder-execute-verb-scope"
      fi
      if ! printf '%s' "${AGENT_PROMPT}" | grep -qE 'scope:[[:space:]]*(code|verdict|analysis|docs)'; then
        deny "builder-execute-verb-scope (F-V7): Builder dispatch must declare 'scope: (code|verdict|analysis|docs)'. Bypass: PF_BYPASS=builder-execute-verb-scope." "builder-execute-verb-scope"
      fi
    else
      log_bypass "builder-execute-verb-scope" "explicit bypass"
    fi
  fi
}

# check_file_scope_intersection
# F-4 (2026-05-17, v2.5.0 PR-9) — File-scope intersection check for Agent dispatch.
#
# When the new dispatch's scope_read intersects an in-flight agent's scope_write,
# the new dispatch reads stale or partial state. Block until producer completes.
#
# Parsing: looks for "scope_write: <paths>" and "scope_read: <paths>" lines in the
# agent prompt. Paths may be comma-separated or single. Missing declarations →
# advisory log + allow (graceful degradation; pre-v2.5.0 agent prompts don't
# declare scope, so absence is the common case until agents are updated).
#
# In-flight detection: looks at .framework-state/active-agents.jsonl events from
# the last 30 minutes (configurable). Start events without a matching stop event
# from subagent-stop hook are considered in-flight. Time-window heuristic — not
# perfect correlation, accepts some false-positive blocking in exchange for
# zero-dependency implementation. v2.5.1 follow-up may refine with explicit
# agent_id correlation.
check_file_scope_intersection() {
  [ ! -f "${ACTIVE_AGENTS:-${STATE_DIR}/active-agents.jsonl}" ] && return 0
  [ "${PF_BYPASS:-}" = "file-scope-intersection" ] && { log_bypass "file-scope-intersection" "explicit bypass"; return 0; }

  local active_agents_file="${STATE_DIR}/active-agents.jsonl"
  local new_scope_read
  new_scope_read=$(printf '%s' "${AGENT_PROMPT}" | grep -oE 'scope_read:[[:space:]]*[^\n]+' | sed 's/^scope_read:[[:space:]]*//' | head -1 | tr -d '[]' || echo "")
  local new_scope_write
  new_scope_write=$(printf '%s' "${AGENT_PROMPT}" | grep -oE 'scope_write:[[:space:]]*[^\n]+' | sed 's/^scope_write:[[:space:]]*//' | head -1 | tr -d '[]' || echo "")

  # Graceful degradation: if no scope declarations in this dispatch, skip the check.
  # Pre-v2.5.0 agent prompts don't declare scope; we allow them through. v2.5.1+
  # follow-up PRs will add scope declarations to all 12 agent prompts, at which
  # point this graceful-degradation branch becomes the exception rather than the
  # default. For now: log the absence for observability.
  if [ -z "${new_scope_read}" ] && [ -z "${new_scope_write}" ]; then
    printf '{"timestamp":"%s","event":"file_scope_intersection_skipped","subagent_type":"%s","reason":"no_scope_declarations"}\n' \
      "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" "${SUBAGENT_TYPE:-unknown}" >> "${STATE_DIR}/trigger-audit.jsonl" 2>/dev/null || true
    return 0
  fi

  # Check intersection with in-flight agents' scope_write.
  # In-flight window: last 30 minutes.
  local now_epoch
  now_epoch=$(date +%s)
  local window_start_epoch=$((now_epoch - 1800))

  # Build a list of in-flight scope_write paths (one per line)
  local in_flight_writes
  in_flight_writes=$(
    awk -v window_start="${window_start_epoch}" '
      /"event":"start"/ {
        # Extract started_at_epoch
        match($0, /"started_at_epoch":[0-9]+/)
        if (RSTART > 0) {
          epoch_str = substr($0, RSTART, RLENGTH)
          sub(/.*:/, "", epoch_str)
          if (epoch_str + 0 >= window_start) {
            # Extract scope_write field
            match($0, /"scope_write":"[^"]*"/)
            if (RSTART > 0) {
              sw_str = substr($0, RSTART, RLENGTH)
              sub(/"scope_write":"/, "", sw_str)
              sub(/"$/, "", sw_str)
              if (length(sw_str) > 0) print sw_str
            }
          }
        }
      }
    ' "${active_agents_file}" 2>/dev/null || echo ""
  )

  if [ -z "${in_flight_writes}" ]; then
    return 0    # nothing in flight; no intersection possible
  fi

  # Check whether any in-flight scope_write path appears in the new scope_read.
  # Simple substring match — robust to comma vs newline separators.
  local conflict_path=""
  while IFS= read -r write_path; do
    [ -z "${write_path}" ] && continue
    # Trim whitespace and try each comma-separated item
    local trimmed
    trimmed=$(printf '%s' "${write_path}" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//' | tr ',' '\n')
    while IFS= read -r single_path; do
      single_path=$(printf '%s' "${single_path}" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
      [ -z "${single_path}" ] && continue
      if printf '%s' "${new_scope_read}" | grep -qF "${single_path}"; then
        conflict_path="${single_path}"
        break 2
      fi
    done <<< "${trimmed}"
  done <<< "${in_flight_writes}"

  if [ -n "${conflict_path}" ]; then
    deny "file-scope-intersection (F-4, 2026-05-17, v2.5.0 PR-9): an in-flight sub-agent has declared scope_write on '${conflict_path}', and the new dispatch's scope_read intersects that path. Reading mid-edit produces stale or partial state — wait for the producer to complete before dispatching the consumer. Per cycle-selection skill Pattern A 'File-scope intersection rule.' Bypass: PF_BYPASS=file-scope-intersection if the producer-vs-consumer ordering is intentional (e.g., concurrent read-only audit on a doc that may be mid-revision)." "file-scope-intersection"
  fi
}

# record_agent_start
# F-4 (2026-05-17, v2.5.0 PR-9) — Record this Agent dispatch's scope declarations
# in .framework-state/active-agents.jsonl so future intersection checks see it
# as in-flight. Paired with hooks/subagent-stop which records the "stop" event
# (PR-10 of v2.5.0).
record_agent_start() {
  local active_agents_file="${STATE_DIR}/active-agents.jsonl"
  mkdir -p "${STATE_DIR}" 2>/dev/null || true
  [ -f "${active_agents_file}" ] || touch "${active_agents_file}"

  local now_epoch now_iso
  now_epoch=$(date +%s)
  now_iso=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  local scope_write_str scope_read_str
  scope_write_str=$(printf '%s' "${AGENT_PROMPT}" | grep -oE 'scope_write:[[:space:]]*[^\n]+' | sed 's/^scope_write:[[:space:]]*//' | head -1 | tr -d '"' || echo "")
  scope_read_str=$(printf '%s' "${AGENT_PROMPT}" | grep -oE 'scope_read:[[:space:]]*[^\n]+' | sed 's/^scope_read:[[:space:]]*//' | head -1 | tr -d '"' || echo "")

  printf '{"started_at":"%s","started_at_epoch":%d,"subagent_type":"%s","scope_write":"%s","scope_read":"%s","event":"start"}\n' \
    "${now_iso}" "${now_epoch}" "${SUBAGENT_TYPE:-unknown}" "${scope_write_str}" "${scope_read_str}" >> "${active_agents_file}"
}

# check_active_gates_for_file_write
# Called for Edit/Write after the legacy tier-selection gate passes.
# Enforces find-similar-implementations IFF listed.
check_active_gates_for_file_write() {
  [ ! -f "${ACTIVE_GATES}" ] && return 0

  # find-similar-implementations
  if grep -q "id: find-similar-implementations" "${ACTIVE_GATES}" 2>/dev/null; then
    if [ "${TOOL_NAME}" = "Write" ]; then
      case "${FILE_PATH_NORM}" in
        */src/lib/*|*/src/components/*|*/src/hooks/*|*/src/utils/*|*/src/primitives/*)
          # New file: target file doesn't exist yet
          if [ ! -f "${FILE_PATH}" ]; then
            # Look up the configured mode (default warn / max=3)
            local mode max
            mode=$(awk -v gid="find-similar-implementations" '
              $0 ~ "id: " gid {found=1}
              found && /enforcement_mode:/ { gsub(/.*enforcement_mode:[[:space:]]*/, ""); print; exit }
            ' "${ACTIVE_GATES}" | tr -d '"')
            max=$(awk -v gid="find-similar-implementations" '
              $0 ~ "id: " gid {found=1}
              found && /max_per_session:/ { gsub(/.*max_per_session:[[:space:]]*/, ""); print; exit }
            ' "${ACTIVE_GATES}" | tr -d '"')
            mode="${mode:-warn}"
            max="${max:-3}"
            warn_handle "find-similar-implementations" "${mode}" "${max}" \
              "find-similar-implementations (audit Item 39): new primitive at ${FILE_PATH_NORM}. Invoke production-framework:find-similar-implementations first — produces 5-line REUSE/ADAPT/NEW candidate table. Bypass: PF_BYPASS=find-similar-implementations."
          fi
          ;;
      esac
    fi
  fi
}

# =============================================================================
# Project-level kill switch
# =============================================================================
if [ -f "${KILL_SWITCH}" ]; then
  log_bypass "PF_GATES_DISABLED" "project-level kill switch active"
  allow
fi

# =============================================================================
# Session-wide bypass
# =============================================================================
if [ -n "${PF_BYPASS_ALL:-}" ] && [ "${PF_BYPASS_ALL}" = "1" ]; then
  if [ -z "${PF_BYPASS_REASON:-}" ]; then
    deny "PF_BYPASS_ALL=1 set without PF_BYPASS_REASON. Set both or use per-rule PF_BYPASS=<rule-id>." "PF_BYPASS_ALL"
  fi
  log_bypass "ALL" "${PF_BYPASS_REASON}"
  allow
fi

# =============================================================================
# Parse tool call from stdin JSON
# =============================================================================
TOOL_NAME=$(printf '%s' "$INPUT" | grep -o '"tool_name"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"tool_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || echo "")
COMMAND=$(printf '%s' "$INPUT" | grep -o '"command"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"command"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || echo "")
FILE_PATH=$(printf '%s' "$INPUT" | grep -o '"file_path"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"file_path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || echo "")
SKILL_NAME=$(printf '%s' "$INPUT" | grep -o '"skill"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"skill"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || echo "")
SUBAGENT_TYPE=$(printf '%s' "$INPUT" | grep -o '"subagent_type"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"subagent_type"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || echo "")
AGENT_PROMPT=$(printf '%s' "$INPUT" | grep -o '"prompt"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"prompt"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || echo "")

FILE_PATH_NORM="${FILE_PATH//\\//}"

# =============================================================================
# Skill / Agent invocation logging + timestamp updates
# =============================================================================
if [ "${TOOL_NAME}" = "Skill" ]; then
  log_invocation "skill" "${SKILL_NAME}"
  case "${SKILL_NAME}" in
    *tier-selection*) update_skill_timestamp "tier_selection_invoked_at" ;;
    *triage*) update_skill_timestamp "triage_invoked_at" ;;
  esac
  allow
fi

if [ "${TOOL_NAME}" = "Agent" ] || [ "${TOOL_NAME}" = "Task" ]; then
  log_invocation "agent" "${SUBAGENT_TYPE}"
  reset_read_count
  check_active_gates_for_agent_dispatch
  check_file_scope_intersection   # F-4 (2026-05-17, v2.5.0 PR-9) — see function definition below
  record_agent_start              # F-4 (2026-05-17, v2.5.0 PR-9) — track this dispatch for future intersection checks
  allow
fi

# =============================================================================
# Read tool — universal floor heavy-read-dispatch
# MED-2 fix: framework-state + .claude-plugin reads must be auto-allowed BEFORE
# increment_read_count, or they pollute the deliverable-read counter.
# =============================================================================
if [ "${TOOL_NAME}" = "Read" ]; then
  # Framework-workflow reads do not count against the deliverable budget
  case "${FILE_PATH_NORM}" in
    */.framework-state/*|*/.claude-plugin/*) allow ;;
  esac
  current_reads=$(increment_read_count)
  if [ "${current_reads}" -ge 4 ]; then
    if [ "${PF_BYPASS:-}" = "heavy-read-dispatch" ]; then
      log_bypass "heavy-read-dispatch" "explicit bypass"
      allow
    fi
    deny "heavy-read-dispatch (universal floor): main session has read >=4 files for one deliverable. Dispatch a production-framework:researcher sub-agent. This is the v1→v2 fork rationale; ignoring it returns the framework to v1's CTO-does-everything-in-main-context failure mode. Bypass: PF_BYPASS=heavy-read-dispatch." "heavy-read-dispatch"
  fi
  allow
fi

# =============================================================================
# Read session state
# =============================================================================
TIER_SELECTION_TS=""
LAST_USER_PROMPT_TS=""
if [ -f "${SESSION_FILE}" ]; then
  TIER_SELECTION_TS=$(grep -o '"tier_selection_invoked_at"[[:space:]]*:[[:space:]]*"[^"]*"' "${SESSION_FILE}" 2>/dev/null | sed 's/.*"tier_selection_invoked_at"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || echo "")
  LAST_USER_PROMPT_TS=$(grep -o '"last_user_prompt_at"[[:space:]]*:[[:space:]]*"[^"]*"' "${SESSION_FILE}" 2>/dev/null | sed 's/.*"last_user_prompt_at"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || echo "")
fi

# =============================================================================
# Legacy gate 2 — Destructive-ops + Legacy gate 5 — Dep-add (Bash only)
# =============================================================================
if [ "${TOOL_NAME}" = "Bash" ]; then
  if printf '%s' "${COMMAND}" | grep -qE 'rm[[:space:]]+-rf|reset[[:space:]]+--hard|push[[:space:]]+(--force|-f)|DROP[[:space:]]+(TABLE|DATABASE|SCHEMA)|TRUNCATE[[:space:]]+TABLE|--no-verify'; then
    if [ "${PF_BYPASS:-}" = "destructive" ]; then
      log_bypass "destructive" "explicit bypass for: ${COMMAND}"
      allow
    fi
    deny "Destructive operation detected. Set PF_BYPASS=destructive + PF_BYPASS_REASON to proceed. Pattern matched: rm -rf | reset --hard | push --force | DROP TABLE | TRUNCATE | --no-verify." "destructive-ops"
  fi
  if printf '%s' "${COMMAND}" | grep -qE '(npm|pnpm|yarn|bun)[[:space:]]+(add|install)[[:space:]]+\S'; then
    if [ "${PF_BYPASS:-}" = "dep-add" ]; then
      log_bypass "dep-add" "explicit bypass"
      allow
    fi
    deny "Dependency install detected. Document the Tool Selection Chain (eliminate / reuse / one-primitive / build-new) in your prior message, OR set PF_BYPASS=dep-add." "dep-add"
  fi
fi

# =============================================================================
# Sub-agent tier-selection inheritance (F-V20)
# =============================================================================
if [ -n "${SUBAGENT_TYPE:-}" ] && [ -n "${TIER_SELECTION_TS}" ] && [ -n "${LAST_USER_PROMPT_TS}" ]; then
  if [[ "${TIER_SELECTION_TS}" > "${LAST_USER_PROMPT_TS}" ]] || [[ "${TIER_SELECTION_TS}" == "${LAST_USER_PROMPT_TS}" ]]; then
    log_invocation "subagent_inherit" "${SUBAGENT_TYPE}"
    allow
  fi
fi

# =============================================================================
# MCP tool invocation logging
# =============================================================================
if [[ "${TOOL_NAME}" == mcp__* ]]; then
  log_invocation "mcp_tool_call" "${TOOL_NAME}"
  allow
fi

# =============================================================================
# Universal floor — Edit/Write checks (no-pii-in-logs, data-loss-disclosure)
# =============================================================================
if [ "${TOOL_NAME}" = "Edit" ] || [ "${TOOL_NAME}" = "Write" ]; then
  # Extract NEW_CONTENT — use greedy match to capture content that may contain
  # escaped quotes (\"). sed -n with greedy .* up to last "} or "," terminator.
  # Then unescape \" → " for predicate matching.
  NEW_CONTENT=$(printf '%s' "$INPUT" | sed -n 's/.*"new_string"[[:space:]]*:[[:space:]]*"\(.*\)"[,}].*/\1/p' | head -1)
  if [ -z "${NEW_CONTENT}" ]; then
    NEW_CONTENT=$(printf '%s' "$INPUT" | sed -n 's/.*"content"[[:space:]]*:[[:space:]]*"\(.*\)"[,}].*/\1/p' | head -1)
  fi
  # Unescape JSON \" → " so PII patterns inside string literals match
  NEW_CONTENT="${NEW_CONTENT//\\\"/\"}"

  # no-pii-in-logs (code files only) — log emission + PII keyword on same line
  # Dropped the trailing strict predicate so console.log(password) matches too.
  case "${FILE_PATH_NORM}" in
    *.ts|*.tsx|*.py|*.go|*.rs|*.java|*.rb|*.js|*.jsx)
      if printf '%s' "${NEW_CONTENT}" | grep -qE '(console\.log|logger\.|print\(|log\.(info|warn|error|debug|fatal)|fmt\.Print|System\.out).*(password|ssn|credit_card|session_token|jwt|api_key|secret_key|access_token|raw_email|raw_phone)'; then
        if [ "${PF_BYPASS:-}" = "no-pii-in-logs" ]; then
          log_bypass "no-pii-in-logs" "explicit bypass"
        else
          deny "no-pii-in-logs (universal floor): log emission appears to include credentials/PII (password, ssn, credit_card, session_token, jwt, api_key, secret, access_token, raw_email, raw_phone). Per ASVS V7.1.1, NIST AU-11, SOC 2 CC6.7. Use correlation IDs + redaction; reference fields by id not value. Bypass: PF_BYPASS=no-pii-in-logs." "no-pii-in-logs"
        fi
      fi
      ;;
  esac

  # data-loss-disclosure (migration files only)
  case "${FILE_PATH_NORM}" in
    */migrations/*)
      if printf '%s' "${NEW_CONTENT}" | grep -qiE '(DROP COLUMN|DROP TABLE|ALTER COLUMN.*TYPE|DELETE FROM)'; then
        if ! printf '%s' "${NEW_CONTENT}" | grep -q 'DATA-LOSS'; then
          if [ "${PF_BYPASS:-}" = "data-loss-disclosure" ]; then
            log_bypass "data-loss-disclosure" "explicit bypass"
          else
            deny "data-loss-disclosure (universal floor): irreversible migration without DATA-LOSS marker. Add a comment: -- DATA-LOSS: <columns/rows lost on rollback>; <recovery path>. Bypass: PF_BYPASS=data-loss-disclosure." "data-loss-disclosure"
          fi
        fi
      fi
      ;;
  esac
fi

# =============================================================================
# Legacy gate 1 — tier-selection on Edit/Write/Bash (task-shape)
# =============================================================================
if [ "${TOOL_NAME}" = "Edit" ] || [ "${TOOL_NAME}" = "Write" ] || [ "${TOOL_NAME}" = "Bash" ]; then
  # Read-only Bash commands skip the gate
  if [ "${TOOL_NAME}" = "Bash" ]; then
    if printf '%s' "${COMMAND}" | grep -qE '^(cat|ls|grep|rg|find|head|tail|wc|git[[:space:]]+(status|diff|log|show|branch))[[:space:]]'; then
      allow
    fi
  fi

  # Auto-allow framework workflow paths
  if [ -n "${FILE_PATH_NORM}" ]; then
    case "${FILE_PATH_NORM}" in
      */.framework-state/*|*/docs/*|*/.claude-plugin/*)
        # Still apply active-gates check (some configurable gates may target docs paths)
        check_active_gates_for_file_write
        allow
        ;;
    esac
  fi

  # PF_BYPASS per-rule
  if [ "${PF_BYPASS:-}" = "tier-selection" ]; then
    log_bypass "tier-selection" "explicit bypass"
    check_active_gates_for_file_write
    allow
  fi

  # No user prompt yet — allow
  if [ -z "${LAST_USER_PROMPT_TS}" ]; then
    check_active_gates_for_file_write
    allow
  fi

  # tier-selection at-or-after last user prompt — allow
  if [ -n "${TIER_SELECTION_TS}" ]; then
    if [[ "${TIER_SELECTION_TS}" > "${LAST_USER_PROMPT_TS}" ]] || [[ "${TIER_SELECTION_TS}" == "${LAST_USER_PROMPT_TS}" ]]; then
      check_active_gates_for_file_write
      allow
    fi
  fi

  # tier-selection not fired since last user prompt → deny
  deny "tier-selection has not been invoked since the latest user prompt. Per ADR-002 D-A bundle: invoke production-framework:tier-selection before Edit/Write/Bash on task-shape prompts. Bypass: PF_BYPASS=tier-selection." "tier-selection"
fi

# =============================================================================
# Default: allow unmatched cases
# =============================================================================
allow
