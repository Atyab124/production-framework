#!/usr/bin/env bash
# =============================================================================
# user-prompt-submit.sh — Update last_user_prompt_at on every user prompt
#
# PURPOSE:
#   Per ADR-002 D-A bundle: hooks/pre-tool-use.sh gates Edit/Write/Bash on
#   "tier-selection invoked AFTER the latest user prompt." That comparison
#   requires last_user_prompt_at to be populated. This hook fires on every
#   UserPromptSubmit event and writes the current UTC timestamp.
#
# CONTRACT:
#   - Receives UserPromptSubmit event JSON via stdin
#   - Outputs nothing to stdout (no context modification)
#   - Exit 0 always; never blocks the prompt
# =============================================================================

set -euo pipefail

# Read stdin to drain it (CC convention)
INPUT=$(cat 2>/dev/null || echo "")

# Determine project state file
PROJECT_DIR="${CLAUDE_PROJECT_DIR:-$(pwd)}"
STATE_DIR="${PROJECT_DIR}/.framework-state"
SESSION_FILE="${STATE_DIR}/session.json"

# If state file missing, init it
if [ ! -f "${SESSION_FILE}" ]; then
  mkdir -p "${STATE_DIR}"
  cat > "${SESSION_FILE}" <<EOF
{
  "session_started_at": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "tier_selection_invoked_at": "",
  "triage_invoked_at": "",
  "last_user_prompt_at": ""
}
EOF
fi

# Update last_user_prompt_at to now (UTC ISO 8601)
NOW=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Filter system events AND pure continuation directives out of last_user_prompt_at
# updates. These should not re-arm task-shape gates (tier-selection, cycle-selection)
# because they do not signal a new user task.
#
# Filtered:
#   - <system-reminder> (F-V9 A2, 2026-05-17): TodoWrite reminders, deferred-tools
#     notifications. Arrive as UserPromptSubmit events but originate from the harness.
#   - <task-notification> (F-8, 2026-05-17): background-agent completions also arrive
#     as UserPromptSubmit. Previously slipped through the system-reminder regex.
#   - Pure continuation directives (F-2, 2026-05-17): "yes" / "continue" / "ok" /
#     "keep going" / "proceed" / "do it" / "do as you recommend" / etc. Bounded
#     match (anchored at start of prompt body, ends the prompt) — avoids false
#     positives on long instructive prompts that happen to start with "yes".
#
# Strength preservation: pre-tool-use gate logic untouched; this filter is the only
# behavioral change. When the filter catches an event, last_user_prompt_at stays at
# its prior (substantive-prompt) value, and the gate's timestamp comparison
# (tier_selection_invoked_at >= last_user_prompt_at) keeps passing.
IS_FILTERED_INPUT=0
if printf '%s' "${INPUT}" | grep -qE '"prompt"[[:space:]]*:[[:space:]]*"<(system-reminder|task-notification)>'; then
  IS_FILTERED_INPUT=1
fi
if [ "${IS_FILTERED_INPUT}" = "0" ]; then
  if printf '%s' "${INPUT}" | grep -qiE '"prompt"[[:space:]]*:[[:space:]]*"(yes|ok|okay|continue|go|sure|yep|proceed|carry on|do it|keep going[^"]{0,40}|do as you recommend[^"]{0,40}|make the decision[^"]{0,80}end[- ]?to[- ]?end[^"]{0,20})[.!?]*"[[:space:]]*[,}]'; then
    IS_FILTERED_INPUT=1
  fi
fi

if [ "${IS_FILTERED_INPUT}" = "0" ]; then
  # Use a temp file + sed to update the field portably (avoid jq dependency per CLAUDE.md zero-deps posture)
  tmp=$(mktemp)
  sed -E "s/\"last_user_prompt_at\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/\"last_user_prompt_at\": \"${NOW}\"/" "${SESSION_FILE}" > "${tmp}"
  mv "${tmp}" "${SESSION_FILE}"
fi

# ---------------------------------------------------------------------------
# Trigger-audit instrumentation (v2.0.3): log a prompt_received event with a
# truncated 200-char prompt prefix for cross-correlation with Skill / Agent
# entries written by pre-tool-use. Best-effort regex extraction; if the prompt
# contains internal quotes it'll truncate at the first one — fine for prefix.
# ---------------------------------------------------------------------------
PROMPT_PREFIX=$(printf '%s' "${INPUT}" | grep -o '"prompt"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"prompt"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' | head -c 200)
# JSON-escape: backslash, quote, then control chars
PROMPT_PREFIX="${PROMPT_PREFIX//\\/\\\\}"
PROMPT_PREFIX="${PROMPT_PREFIX//\"/\\\"}"
PROMPT_PREFIX="${PROMPT_PREFIX//$'\n'/\\n}"
PROMPT_PREFIX="${PROMPT_PREFIX//$'\r'/\\r}"
PROMPT_PREFIX="${PROMPT_PREFIX//$'\t'/\\t}"
printf '{"timestamp":"%s","event":"prompt_received","prefix":"%s"}\n' "${NOW}" "${PROMPT_PREFIX}" >> "${STATE_DIR}/trigger-audit.jsonl"

exit 0
